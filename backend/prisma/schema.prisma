generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Prefeitura {
  id             Int          @id @default(autoincrement())
  nome           String
  slug           String       @unique
  logoUrl        String?
  corPrimaria    String       @default("#0d6efd")
  corSecundaria  String       @default("#6c757d")
  limiteCampeonatos Int       @default(3)
  usuarios       Usuario[]
  campeonatos    Campeonato[]
  equipes        Equipe[]
  categorias     Categoria[]
  perfis         PerfilAcesso[]
}

model Usuario {
  id           Int         @id @default(autoincrement())
  email        String      @unique
  senha        String
  role         String      @default("COMUM") // COMUM | MASTER
  prefeitura   Prefeitura? @relation(fields: [prefeituraId], references: [id])
  prefeituraId Int?
  perfil       PerfilAcesso? @relation(fields: [perfilId], references: [id])
  perfilId     Int?
  historicoEdicoes HistoricoEdicaoSumula[]
}

model Equipe {
  id            Int            @id @default(autoincrement())
  nome          String
  responsavel   String
  telefone      String
  local         String?
  logoUrl       String?
  categoria     String?
  participacoes Participacao[]
  vinculos      Vinculo[]
  prefeitura    Prefeitura?    @relation(fields: [prefeituraId], references: [id])
  prefeituraId  Int?
  jogosMandante Jogo[]         @relation("Mandante")
  jogosVisitante Jogo[]        @relation("Visitante")
  eventos       Evento[]
}

model Campeonato {
  id            Int            @id @default(autoincrement())
  nome          String
  descricao     String?
  ano           Int?
  formato       String?
  categoria     String?
  dataInicio    String
  dataFim       String
  status        String         @default("Inscrições Abertas")
  regrasDesempateGeral Json?
  regrasDesempate2Equipes   Json?
  regrasDesempate3MaisEquipes Json?
  participacoes Participacao[]
  rodadas       Rodada[]
  classificadosPorChave Int        @default(4)
  regulamentoUrl String?
  prefeitura    Prefeitura?    @relation(fields: [prefeituraId], references: [id])
  prefeituraId  Int?
}

model Participacao {
  id           Int        @id @default(autoincrement())
  campeonato   Campeonato @relation(fields: [campeonatoId], references: [id])
  campeonatoId Int
  equipe       Equipe     @relation(fields: [equipeId], references: [id])
  equipeId     Int
  chave        String?
}

model Atleta {
  id       Int       @id @default(autoincrement())
  nome     String
  cpf      String?
  dataNasc String?
  vinculos Vinculo[]
  eventos  Evento[]
}

model Vinculo {
  id           Int     @id @default(autoincrement())
  atleta       Atleta  @relation(fields: [atletaId], references: [id])
  atletaId     Int
  equipe       Equipe  @relation(fields: [equipeId], references: [id])
  equipeId     Int
  tipo         String?
  dataFim      String?
}

model Rodada {
  id           Int        @id @default(autoincrement())
  numero       Int
  nome         String?
  tipo         String     @default("GRUPO") // GRUPO ou MATA_MATA
  campeonato   Campeonato @relation(fields: [campeonatoId], references: [id])
  campeonatoId Int
  jogos        Jogo[]
}

model Jogo {
  id            Int      @id @default(autoincrement())
  rodada        Rodada   @relation(fields: [rodadaId], references: [id])
  rodadaId      Int
  numero        Int
  mandante      Equipe?  @relation("Mandante", fields: [mandanteId], references: [id])
  mandanteId    Int?
  visitante     Equipe?  @relation("Visitante", fields: [visitanteId], references: [id])
  visitanteId   Int?
  mandantePlaceholder String?
  visitantePlaceholder String?
  mandanteNome  String
  visitanteNome String
  golsMandante      Int      @default(0)
  golsVisitante     Int      @default(0)
  penaltisMandante  Int?
  penaltisVisitante Int?
  data              String
  horario       String?
  local         String?
  status        String   @default("Agendado")
  chave         String?
  sumulaUrl     String?
  eventos       Evento[]
  historico     HistoricoEdicaoSumula[]
}

model Evento {
  id       Int    @id @default(autoincrement())
  jogo     Jogo   @relation(fields: [jogoId], references: [id])
  jogoId   Int
  atleta   Atleta @relation(fields: [atletaId], references: [id])
  atletaId Int
  equipe   Equipe? @relation(fields: [equipeId], references: [id])
  equipeId Int?
  gols     Int    @default(0)
  gc       Int    @default(0)
  am       Int    @default(0)
  vm       Int    @default(0)
}

model Categoria {
  id           Int        @id @default(autoincrement())
  nome         String
  prefeitura   Prefeitura @relation(fields: [prefeituraId], references: [id])
  prefeituraId Int

  @@unique([nome, prefeituraId])
}

// Audit log: registra toda edição de súmula finalizada feita por usuário MASTER
model HistoricoEdicaoSumula {
  id         Int      @id @default(autoincrement())
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId  Int
  jogo       Jogo     @relation(fields: [jogoId], references: [id])
  jogoId     Int
  dataEdicao DateTime @default(now())
  motivo     String?  // justificativa opcional informada pelo árbitro/admin
}

model PerfilAcesso {
  id           Int        @id @default(autoincrement())
  nome         String
  permissoes   Json       // ["equipes", "jogos", "sumulas", ...]
  prefeitura   Prefeitura @relation(fields: [prefeituraId], references: [id])
  prefeituraId Int
  usuarios     Usuario[]
}
